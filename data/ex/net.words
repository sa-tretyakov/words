cont wifi
load wifi-config.json // Напишите в файле свои данные
: wifiOk
if ssid == ""
ln print "Введите wifisave "ssid" "ssidPass""
ln print "Запусти сеть start"
;
: start
if ssid != ""
print "Подключаюсь к сети "
ln print ssid
modeSta
onSta ssid ssidPass
->
print "STA Start "
print ipSta
ln
onHTTP
+loop "HTTP"
onSoket
+loop "Soket"
;
: wifisave
wifi
ssid =
ssidPass =
json>file "/wifi-config.json"
json>
json>serial
main
;
start
wifiOk